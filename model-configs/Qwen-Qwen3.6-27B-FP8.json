// Qwen3.6-27B-FP8 — Model configuration
// Source: HuggingFace model card, tokenizer_config.json Jinja template verification
// https://huggingface.co/Qwen/Qwen3.6-27B-FP8
// Verified 2026-07-10.
//
// Chat template parameters (all Jinja template variables, passed via chat_template_kwargs):
//   - `enable_thinking: true/false` — enables/disables reasoning token generation
//   - `preserve_thinking: true` — keeps <think>...</think> blocks visible in multi-turn
//     conversation history. Controls this Jinja conditional in the template:
//     `{%- if (preserve_thinking is defined and preserve_thinking is true) or ... %}`
//     Without it, thinking is stripped from earlier turns. Useful for coding/agent
//     scenarios where the model benefits from seeing prior reasoning steps.
//
// Copy the "id" object below into your settings.json:
//   "vllm-copilot.models": [ <PASTE_HERE> ]
//
// Requirements:
//   - vLLM launched with --reasoning-parser qwen3
//   - For tool calling: also add --enable-auto-tool-choice --tool-call-parser qwen3_coder
//   - For vision: do NOT use --language-model-only
//
// Token budgets:
//   - Context window: 262,144 tokens (fixed by vLLM)
//   - maxOutputTokens: 32,768 (official recommendation for "most queries")
//   - maxInputTokens: auto-computed as ~229,376 (context window minus output)
//   - For complex tasks needing larger output, increase maxOutputTokens in settings
//
// Modes (all values from official Qwen3.6 model card):
//   - Think (General):  Diverse reasoning, higher temperature
//   - Think (Precise):  Deterministic coding, lower temperature
//   - No Think:         Direct responses, no thinking tokens
//


{
  "id": "Qwen/Qwen3.6-27B-FP8",
  "vllmModelId": "Qwen/Qwen3.6-27B-FP8",
  "displayName": "Qwen3.6-27B-FP8",
  "family": "qwen3_5",
  "maxOutputTokens": 32768,
  "capabilities": {
    "toolCalling": true,
    "imageInput": true
  },
  "modelModes": {
    "Think (General)": {
      "chat_template_kwargs": {
        "enable_thinking": true,
        "preserve_thinking": true
      },
      "temperature": 1.0,
      "top_p": 0.95,
      "top_k": 20,
      "min_p": 0.0,
      "presence_penalty": 0.0,
      "repetition_penalty": 1.0
    },
    "Think (Precise)": {
      "chat_template_kwargs": {
        "enable_thinking": true,
        "preserve_thinking": true
      },
      "temperature": 0.6,
      "top_p": 0.95,
      "top_k": 20,
      "min_p": 0.0,
      "presence_penalty": 0.0,
      "repetition_penalty": 1.0
    },
    "No Think": {
      "chat_template_kwargs": {
        "enable_thinking": false
      },
      "temperature": 0.7,
      "top_p": 0.8,
      "top_k": 20,
      "min_p": 0.0,
      "presence_penalty": 1.5,
      "repetition_penalty": 1.0
    }
  },
  "defaultMode": "Think (General)"
}
